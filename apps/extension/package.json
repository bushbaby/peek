{
  "name": "@peek/extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "node scripts/sync-version.mjs && vite build && node scripts/package-extension.mjs",
    "sync-version": "node scripts/sync-version.mjs",
    "package": "node scripts/package-extension.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@peek/selector": "workspace:*"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.23",
    "@peek/tsconfig": "workspace:*",
    "@types/chrome": "^0.0.321",
    "typescript": "^5.8.0",
    "vite": "^5.0.0"
  }
}
